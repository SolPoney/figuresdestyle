{
	"$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"ignore": ["**/*.html", "**/*.css", "frontend/**", "**/dist/**", "**/node_modules/**"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"include": ["backend/src/**/*.ts"]
	},
	"linter": {
		"enabled": true,
		"include": ["backend/src/**/*.ts"],
		"rules": {
			"recommended": true
		}
	},
	"css": {
		"formatter": { "enabled": false },
		"linter": { "enabled": false }
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
